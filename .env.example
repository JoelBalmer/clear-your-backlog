# Reference only. The real values live in Vercel and are pulled locally with:
#   vercel env pull .env.development.local
# (which is gitignored). Don't fill these in by hand unless you're not using Vercel.

# --- Neon (provisioned via Vercel Marketplace) ---
DATABASE_URL=                       # pooled, used by API routes (Drizzle + neon-http)
DATABASE_URL_UNPOOLED=              # direct, used by drizzle-kit migrate
PGHOST=
PGUSER=
PGDATABASE=
PGPASSWORD=

# --- Clerk (provisioned via Vercel Marketplace) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # vite.config.ts aliases this to VITE_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=                   # server-only; verify JWT in API routes

# --- Twitch / IGDB (manually added in Phase 4) ---
TWITCH_CLIENT_ID=                   # server-only; used by /api/igdb-search
TWITCH_CLIENT_SECRET=               # server-only
